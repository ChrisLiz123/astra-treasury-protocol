# Hardhat 3 keystore variables are recommended for secrets.
# These names match hardhat.config.ts.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_SEPOLIA_PRIVATE_KEY=0xYOUR_TESTNET_PRIVATE_KEY
BASE_MAINNET_RPC_URL=https://mainnet.base.org
BASE_MAINNET_PRIVATE_KEY=0xYOUR_MAINNET_PRIVATE_KEY_DO_NOT_USE_FOR_TESTING

# Optional allocation wallets. If omitted, deploy script uses the deployer/admin wallet for that allocation.
ASTRA_ECOSYSTEM_WALLET=0x0000000000000000000000000000000000000000
ASTRA_LIQUIDITY_WALLET=0x0000000000000000000000000000000000000000
ASTRA_TEAM_WALLET=0x0000000000000000000000000000000000000000
ASTRA_COMMUNITY_WALLET=0x0000000000000000000000000000000000000000
ASTRA_ADVISORS_WALLET=0x0000000000000000000000000000000000000000
ASTRA_SIGNALER_WALLET=0x0000000000000000000000000000000000000000
